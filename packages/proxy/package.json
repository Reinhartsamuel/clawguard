{
  "name": "@clawguard/proxy",
  "version": "0.1.0",
  "type": "module",
  "main": "dist/index.js",
  "exports": {
    ".": "./dist/index.js",
    "./src/*": "./src/*"
  },
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "build": "tsup",
    "test": "vitest run --exclude test/store.test.ts --exclude test/budget.test.ts && bun test test/store.test.ts test/budget.test.ts"
  },
  "dependencies": {
    "hono": "^4.7.0",
    "@hono/node-server": "^1.13.0",
    "pino": "^9.6.0"
  },
  "devDependencies": {
    "tsup": "^8.4.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0",
    "@types/node": "^22.0.0",
    "@types/bun": "^1.2.0"
  }
}
